{
  "name": "ai-development-agent",
  "description": "Constraint template for AI development agents (e.g., Claude Code, Cursor, GitHub Copilot)",
  "constraints": {
    "scope": {
      "allowed_actions": ["read", "write", "edit", "grep", "glob", "list"],
      "blocked_actions": ["deploy", "publish", "delete_branch", "force_push"],
      "requires_approval": ["bash_execute", "git_push", "create_pr"]
    },
    "financial": {
      "max_spend_usd": 0,
      "budget_period": "none",
      "description": "No financial operations allowed for development agents"
    },
    "temporal": {
      "valid_hours": "00:00-23:59",
      "timezone": "UTC",
      "max_session_hours": 8,
      "description": "No time restrictions by default"
    },
    "communication": {
      "allowed_targets": ["internal_repos", "localhost"],
      "blocked_targets": ["external_apis", "social_media", "email"],
      "description": "Internal repositories only"
    },
    "data_access": {
      "allowed_patterns": ["src/**", "tests/**", "docs/**", "*.py", "*.md", "*.json"],
      "blocked_patterns": [".env", "*.pem", "*.key", "credentials.*", "secrets.*"],
      "description": "Source code and documentation only, no secrets"
    }
  },
  "posture": "supervised",
  "audit_level": "all_actions"
}
