{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eatp.terrene.dev/schemas/genesis-record.schema.json",
  "title": "EATP Genesis Record",
  "description": "Cryptographic proof of agent authorization — the root of trust for an agent.",
  "type": "object",
  "required": [
    "id",
    "agent_id",
    "authority_id",
    "authority_type",
    "created_at",
    "signature",
    "signature_algorithm"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this genesis record (format: gen-{uuid4})",
      "pattern": "^gen-[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "agent_id": {
      "type": "string",
      "description": "Unique identifier of the agent being authorized"
    },
    "authority_id": {
      "type": "string",
      "description": "ID of the authority granting trust"
    },
    "authority_type": {
      "type": "string",
      "enum": ["organization", "system", "human"],
      "description": "Type of authority"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Optional ISO 8601 expiration timestamp"
    },
    "signature": {
      "type": "string",
      "description": "Base64-encoded Ed25519 signature over the record"
    },
    "signature_algorithm": {
      "type": "string",
      "const": "Ed25519",
      "description": "Signature algorithm used"
    },
    "metadata": {
      "type": "object",
      "description": "Additional context and configuration",
      "additionalProperties": true
    },
    "human_origin": {
      "type": ["object", "null"],
      "description": "EATP human origin tracking",
      "properties": {
        "human_id": { "type": "string" },
        "authorization_timestamp": { "type": "string", "format": "date-time" },
        "authorization_method": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
