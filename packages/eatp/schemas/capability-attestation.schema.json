{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eatp.terrene.dev/schemas/capability-attestation.schema.json",
  "title": "EATP Capability Attestation",
  "description": "Attestation of a specific capability granted to an agent.",
  "type": "object",
  "required": [
    "id",
    "agent_id",
    "capability",
    "capability_type",
    "granted_at",
    "signature"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique attestation identifier (format: cap-{uuid4})"
    },
    "agent_id": {
      "type": "string",
      "description": "Agent this capability is granted to"
    },
    "capability": {
      "type": "string",
      "description": "Name of the capability (e.g., 'analyze_data')"
    },
    "capability_type": {
      "type": "string",
      "enum": ["access", "action", "delegation", "administrative"],
      "description": "Type of capability"
    },
    "scope": {
      "type": "object",
      "description": "Scope restrictions for this capability",
      "additionalProperties": true
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Constraints specific to this capability"
    },
    "granted_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "granted_by": {
      "type": ["string", "null"],
      "description": "Authority or agent that granted this capability"
    },
    "signature": {
      "type": "string",
      "description": "Base64-encoded Ed25519 signature"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
