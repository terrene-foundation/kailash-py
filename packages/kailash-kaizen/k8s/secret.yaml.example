apiVersion: v1
kind: Secret
metadata:
  name: kaizen-secrets
  namespace: kaizen
type: Opaque
stringData:
  # OpenAI API Key
  openai-api-key: "your-openai-api-key-here"

  # Anthropic API Key
  anthropic-api-key: "your-anthropic-api-key-here"

  # Database URL (PostgreSQL)
  database-url: "postgresql://user:password@hostname:5432/database"

  # Redis URL
  redis-url: "redis://hostname:6379/0"

---
# Example: Using external secret management (sealed-secrets, external-secrets, etc.)
# apiVersion: bitnami.com/v1alpha1
# kind: SealedSecret
# metadata:
#   name: kaizen-secrets
#   namespace: kaizen
# spec:
#   encryptedData:
#     openai-api-key: AgBY... # Encrypted value
#     anthropic-api-key: AgBZ... # Encrypted value
