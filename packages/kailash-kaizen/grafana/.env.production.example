# Grafana Production Configuration
# ================================
# Copy to .env.production and populate with actual values
# IMPORTANT: .env.production should NEVER be committed to git

# ============================================================================
# GRAFANA ADMIN CREDENTIALS
# ============================================================================
# Change these immediately! Default admin/admin is a major security vulnerability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_12_CHARS

# ============================================================================
# SSL/TLS CONFIGURATION
# ============================================================================
# For production, HTTPS is mandatory for PCI-DSS, SOC2, HIPAA compliance
GRAFANA_SERVER_PROTOCOL=https
GRAFANA_SERVER_DOMAIN=grafana.example.com
GRAFANA_SERVER_CERT_FILE=/etc/grafana/ssl/grafana.crt
GRAFANA_SERVER_KEY_FILE=/etc/grafana/ssl/grafana.key

# ============================================================================
# OAUTH CONFIGURATION (Optional - Recommended for Production)
# ============================================================================
# Supported providers: Google, GitHub, Okta, Azure AD, GitLab
# Example: Google OAuth 2.0
GRAFANA_AUTH_OAUTH_ENABLED=false
GRAFANA_AUTH_OAUTH_NAME=OAuth
GRAFANA_AUTH_OAUTH_CLIENT_ID=your_google_client_id_here
GRAFANA_AUTH_OAUTH_CLIENT_SECRET=your_google_client_secret_here
GRAFANA_AUTH_OAUTH_SCOPES=openid email profile
GRAFANA_AUTH_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GRAFANA_AUTH_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GRAFANA_AUTH_OAUTH_API_URL=https://openidconnect.googleapis.com/v1/userinfo
GRAFANA_AUTH_OAUTH_ALLOWED_DOMAINS=example.com

# For GitHub OAuth:
# GRAFANA_AUTH_OAUTH_AUTH_URL=https://github.com/login/oauth/authorize
# GRAFANA_AUTH_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token
# GRAFANA_AUTH_OAUTH_API_URL=https://api.github.com/user
# GRAFANA_AUTH_OAUTH_ALLOWED_ORGANIZATIONS=your-org

# For Okta:
# GRAFANA_AUTH_OAUTH_AUTH_URL=https://your-domain.okta.com/oauth2/v1/authorize
# GRAFANA_AUTH_OAUTH_TOKEN_URL=https://your-domain.okta.com/oauth2/v1/token
# GRAFANA_AUTH_OAUTH_API_URL=https://your-domain.okta.com/oauth2/v1/userinfo

# ============================================================================
# LDAP CONFIGURATION (Optional - For Enterprise Environments)
# ============================================================================
GRAFANA_AUTH_LDAP_ENABLED=false
GRAFANA_AUTH_LDAP_CONFIG_FILE=/etc/grafana/ldap.toml

# ============================================================================
# SECURITY SETTINGS (Production Hardening)
# ============================================================================
# Disable Gravatar to prevent external service leakage
GRAFANA_SECURITY_DISABLE_GRAVATAR=true

# Enable secure cookies (requires HTTPS)
GRAFANA_SECURITY_COOKIE_SECURE=true

# HTTP Strict Transport Security (HSTS)
GRAFANA_SECURITY_STRICT_TRANSPORT_SECURITY=true
GRAFANA_SECURITY_STRICT_TRANSPORT_SECURITY_MAX_AGE=31536000
GRAFANA_SECURITY_STRICT_TRANSPORT_SECURITY_PRELOAD=true

# Prevent MIME type sniffing
GRAFANA_SECURITY_X_CONTENT_TYPE_OPTIONS=true

# Enable XSS protection
GRAFANA_SECURITY_X_XSS_PROTECTION=true

# Content Security Policy
GRAFANA_SECURITY_CONTENT_SECURITY_POLICY=true

# Disable anonymous access (production best practice)
GRAFANA_AUTH_ANONYMOUS_ENABLED=false

# Disable user sign-up (use OAuth/LDAP instead)
GRAFANA_USERS_ALLOW_SIGN_UP=false

# ============================================================================
# PROMETHEUS CONFIGURATION
# ============================================================================
# Prometheus basic authentication
PROMETHEUS_USER=prometheus
PROMETHEUS_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_12_CHARS

# ============================================================================
# JAEGER + ELASTICSEARCH CONFIGURATION
# ============================================================================
# Jaeger storage backend
SPAN_STORAGE_TYPE=elasticsearch

# Elasticsearch connection
ES_SERVER_URLS=https://elasticsearch:9200
ES_USERNAME=elastic
ES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_12_CHARS

# Elasticsearch TLS
ES_TLS_ENABLED=true
ES_TLS_SKIP_HOST_VERIFY=false

# Jaeger Collector settings
COLLECTOR_OTLP_ENABLED=true
COLLECTOR_ZIPKIN_HOST_PORT=:9411

# ============================================================================
# PRODUCTION DEPLOYMENT SETTINGS
# ============================================================================
# External URL (for reverse proxy deployments)
GRAFANA_SERVER_ROOT_URL=https://grafana.example.com

# Database (optional - for multi-instance Grafana)
# Default: SQLite (single instance)
# Production: PostgreSQL/MySQL (multi-instance, HA)
# GF_DATABASE_TYPE=postgres
# GF_DATABASE_HOST=postgres:5432
# GF_DATABASE_NAME=grafana
# GF_DATABASE_USER=grafana
# GF_DATABASE_PASSWORD=CHANGE_ME

# SMTP (for alerting)
# GF_SMTP_ENABLED=true
# GF_SMTP_HOST=smtp.example.com:587
# GF_SMTP_USER=grafana@example.com
# GF_SMTP_PASSWORD=CHANGE_ME
# GF_SMTP_FROM_ADDRESS=grafana@example.com

# ============================================================================
# NOTES
# ============================================================================
# 1. Generate SSL certificates: ./scripts/generate-certs.sh
# 2. For production, use Let's Encrypt or your organization's CA
# 3. Update GRAFANA_SERVER_DOMAIN to match your actual domain
# 4. Configure OAuth for enterprise SSO (Google, Okta, Azure AD)
# 5. Use strong passwords (min 12 characters, alphanumeric + special chars)
# 6. Enable SMTP for email alerting
# 7. Consider PostgreSQL/MySQL for multi-instance deployments
# 8. Test in staging environment before production deployment
