        validation_result = validator.validate(signature)

        assert validation_result.is_valid == True

        # Compile
        compiler = SignatureCompiler()
        config = {"model": "test-model", "temperature": 0.7}
        workflow_config = compiler.compile_to_workflow_config(signature, config)

        assert workflow_config["node_type"] is not None
        assert workflow_config["node_params"] is not None

    def test_error_propagation(self):
