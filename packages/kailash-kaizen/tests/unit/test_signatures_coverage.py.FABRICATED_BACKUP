class TestSignature:
    """Test Signature core functionality for coverage."""

    def test_signature_initialization(self):
        """Test Signature can be initialized with required parameters."""
        signature = Signature(
            inputs=["question", "context"],
            outputs=["answer", "reasoning"],
            signature_type="multi_io",
            name="test_signature"
        )

        assert signature.inputs == ["question", "context"]
        assert signature.outputs == ["answer", "reasoning"]
        assert signature.signature_type == "multi_io"
        assert signature.name == "test_signature"

    def test_signature_default_initialization(self):
        """Test Signature initialization with defaults."""
        signature = Signature(
            inputs=["input"],
            outputs=["output"]
        )

        assert signature.signature_type == "basic"
        assert signature.name.startswith("signature_")
        assert signature.input_types == {}
        assert signature.output_types == {}
        assert signature.parameters == {}

    def test_signature_enterprise_features(self):
        """Test Signature with enterprise features."""
        signature = Signature(
            inputs=["sensitive_data"],
            outputs=["processed_data"],
            requires_privacy_check=True,
            requires_audit_trail=True,
            supports_multi_modal=True
        )

        assert signature.requires_privacy_check == True
        assert signature.requires_audit_trail == True
        assert signature.supports_multi_modal == True

    def test_signature_has_list_outputs(self):
        """Test has_list_outputs property."""
        # Signature without list outputs
        signature1 = Signature(
            inputs=["input"],
            outputs=["output1", "output2"]
        )
        assert signature1.has_list_outputs == False

        # Signature with list outputs
        signature2 = Signature(
            inputs=["input"],
            outputs=["output1", ["list_item1", "list_item2"]]
        )
        assert signature2.has_list_outputs == True

    def test_signature_performance_hooks(self):
        """Test performance hook management."""
        signature = Signature(
            inputs=["input"],
            outputs=["output"]
        )

        # Initially no performance tracking
        assert signature.has_performance_tracking == False
        assert len(signature.performance_hooks) == 0

        # Add performance hook
        signature.add_performance_hook("execution_time")
        assert signature.has_performance_tracking == True
        assert "execution_time" in signature.performance_hooks

        # Don't add duplicate hooks
        signature.add_performance_hook("execution_time")
        assert len(signature.performance_hooks) == 1

    def test_signature_to_dict(self):
        """Test signature dictionary conversion."""
        signature = Signature(
            inputs=["question"],
            outputs=["answer"],
            signature_type="basic",
            name="test_signature",
            description="Test signature description",
            execution_pattern="chain_of_thought"
        )

        signature_dict = signature.to_dict()

        assert signature_dict["inputs"] == ["question"]
        assert signature_dict["outputs"] == ["answer"]
        assert signature_dict["signature_type"] == "basic"
        assert signature_dict["name"] == "test_signature"
        assert signature_dict["description"] == "Test signature description"
        assert signature_dict["execution_pattern"] == "chain_of_thought"


