class TestSignatureIntegration:
    """Test integration between signature system components."""

    def test_complete_signature_workflow(self):
        """Test complete signature processing workflow."""
        # Parse signature
        parser = SignatureParser()
        parse_result = parser.parse("context, question -> reasoning, answer")

        assert parse_result.is_valid == True

        # Create signature from parse result
        signature = Signature(
            inputs=parse_result.inputs,
            outputs=parse_result.outputs,
            signature_type=parse_result.signature_type
        )

        # Validate signature
        validator = SignatureValidator()
        validation_result = validator.validate(signature)

        assert validation_result.is_valid == True

        # Optimize signature
        optimizer = SignatureOptimizer()
        optimized_signature = optimizer.optimize(signature, "performance")

        assert optimized_signature.optimization_enabled == True

        # Compile to workflow
        compiler = SignatureCompiler()
        workflow_params = compiler.compile_to_workflow_params(optimized_signature)

        assert "node_type" in workflow_params
        assert "parameters" in workflow_params

