class TestSignatureValidator:
    """Test SignatureValidator implementation for coverage."""

    def test_validator_initialization(self):
        """Test SignatureValidator initialization."""
        validator = SignatureValidator()

        assert hasattr(validator, 'supported_modalities')
        assert 'text' in validator.supported_modalities
        assert 'image' in validator.supported_modalities

    def test_validate_basic_signature(self):
        """Test validating basic signature."""
        validator = SignatureValidator()
        signature = Signature(
            inputs=["question"],
            outputs=["answer"]
        )

        result = validator.validate(signature)

        assert result.is_valid == True
        assert len(result.errors) == 0

    def test_validate_signature_with_errors(self):
        """Test validating signature with errors."""
        validator = SignatureValidator()

        # Signature with no inputs
        signature = Signature(
            inputs=[],
            outputs=["answer"]
        )

        result = validator.validate(signature)

        assert result.is_valid == False
        assert len(result.errors) > 0
        assert any("at least one input" in error for error in result.errors)

    def test_validate_type_annotations(self):
        """Test validating type annotations."""
        validator = SignatureValidator()

        signature = Signature(
            inputs=["question"],
            outputs=["answer"],
            input_types={"question": "text", "unknown_input": "text"},
            output_types={"answer": "text", "unknown_output": "text"}
        )

        result = validator.validate(signature)

        assert result.is_valid == False
        assert any("unknown input" in error.lower() for error in result.errors)
        assert any("unknown output" in error.lower() for error in result.errors)

    def test_validate_multimodal_signature(self):
        """Test validating multi-modal signature."""
        validator = SignatureValidator()

        # Valid multi-modal signature
        signature = Signature(
            inputs=["text_input", "image_input"],
            outputs=["description"],
            supports_multi_modal=True,
            input_types={"text_input": "text", "image_input": "image"}
        )

        result = validator.validate(signature)

        assert result.is_valid == True
        assert result.multi_modal_supported == True
        assert "text" in result.supported_modalities
        assert "image" in result.supported_modalities

        # Invalid multi-modal signature with unsupported modality
        signature_invalid = Signature(
            inputs=["text_input", "unknown_input"],
            outputs=["description"],
            supports_multi_modal=True,
            input_types={"text_input": "text", "unknown_input": "unsupported_type"}
        )

        result = validator.validate(signature_invalid)

        assert result.is_valid == False
        assert any("unsupported modality" in error.lower() for error in result.errors)

    def test_validate_list_outputs(self):
        """Test validating signatures with list outputs."""
        validator = SignatureValidator()

        signature = Signature(
            inputs=["topic"],
            outputs=[["item1", "item2"], "summary"],
            output_types={"item1": "text", "item2": "text", "summary": "text"}
        )

        result = validator.validate(signature)

        assert result.is_valid == True
        assert result.has_type_checking == True


