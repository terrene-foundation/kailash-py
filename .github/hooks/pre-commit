#!/bin/bash
# Pre-commit hook to prevent manual TODO file edits

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Check if any TODO files are being committed
TODO_FILES=$(git diff --cached --name-only | grep -E "# contrib (removed)/project/todos/.*\.md$")

if [ -n "$TODO_FILES" ]; then
    echo -e "${RED}❌ ERROR: Manual TODO file edits detected!${NC}"
    echo ""
    echo -e "${YELLOW}Files detected:${NC}"
    echo "$TODO_FILES"
    echo ""
    echo -e "${RED}TODO files should NEVER be edited manually.${NC}"
    echo ""
    echo -e "${GREEN}Instead, use Claude Code:${NC}"
    echo "  • Update task status: \"Update my progress on [task]: [status]\""
    echo "  • Report completion: \"I've completed [task]\""
    echo "  • Add new tasks: Through Team Lead planning session"
    echo ""
    echo -e "${YELLOW}To fix this:${NC}"
    echo "  1. Unstage the TODO files: git restore --staged $TODO_FILES"
    echo "  2. Revert local changes: git restore $TODO_FILES"
    echo "  3. Use Claude Code for updates instead"
    echo ""
    echo "See: # contrib (removed)/operations/claude-code-workflows/COMMON_MISTAKES.md"
    exit 1
fi

# Check for direct GitHub Project board manipulation comments
PROJECT_PATTERNS="manually updated project|dragged card|moved to column|assigned myself"
SUSPICIOUS_COMMITS=$(git diff --cached | grep -iE "$PROJECT_PATTERNS")

if [ -n "$SUSPICIOUS_COMMITS" ]; then
    echo -e "${YELLOW}⚠️  WARNING: Possible manual project management detected${NC}"
    echo ""
    echo "Found references to manual project updates in your commits."
    echo "Remember: All project management should go through Claude Code!"
    echo ""
    echo "Continue anyway? (y/n)"
    read -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# All checks passed
exit 0
