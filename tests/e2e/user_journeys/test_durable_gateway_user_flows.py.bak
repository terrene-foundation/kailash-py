        """Test analytics workflow with AI-generated insights."""
        async with httpx.AsyncClient(base_url=BASE_URL) as client:
            # Generate some test data first
            for i in range(10):
                order_request = {
                    "customer_email": f"analytics_test_{i}@example.com",
                    "customer_name": f"Analytics User {i}",
                    "items": [
                        {
                            "product_id": f"PROD00{(i % 5) + 1}",
