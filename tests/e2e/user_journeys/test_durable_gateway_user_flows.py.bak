                        }
                    ],
                }
                await client.post("/ecommerce/execute", json=order_request)

            # Run analytics
            analytics_request = {"time_range": "30 days", "segment": "all"}

            response = await client.post(
                "/analytics/execute",
                json=analytics_request,
                timeout=60.0,  # AI might take time
            )

            assert response.status_code == 200
            report = response.json()

            # Verify report structure
            assert "report_id" in report
            assert "data_summary" in report
            assert "ai_insights" in report
            assert "metrics" in report

            # Check AI generated insights
            assert len(report["ai_insights"]) > 100  # Should have meaningful content

    @pytest.mark.asyncio
    async def test_batch_processing_with_resume(self, gateway_with_workflows):
        """Test batch processing with checkpoint and resume capability."""
        async with httpx.AsyncClient(base_url=BASE_URL) as client:
            # Create a batch job
            batch_items = [
                {"id": i, "data": f"item_{i}", "value": random.randint(100, 1000)}
                for i in range(50)
            ]

            batch_request = {
                "job_type": "data_processing",
                "items": batch_items,
                "batch_size": 10,
            }

            response = await client.post(
                "/batch_processing/execute", json=batch_request, timeout=60.0
            )

            assert response.status_code == 200
            result = response.json()

            # Verify batch completed
            assert "summary" in result
            summary = result["summary"]

            assert summary["total_items"] == 50
            assert summary["successful"] + summary["failed"] == summary["total_items"]
            assert summary["success_rate"] > 80  # Most should succeed

            # Check checkpoints were created
            request_id = response.headers.get("X-Request-ID")
            status_response = await client.get(f"/durability/requests/{request_id}")

            status = status_response.json()
            assert status["checkpoints"] > 3  # Multiple checkpoints during processing

    @pytest.mark.asyncio
    async def test_customer_support_flow(self, gateway_with_workflows):
        """Test customer support workflow with AI assistance."""
        async with httpx.AsyncClient(base_url=BASE_URL) as client:
            # Submit a support request
            support_request = {
                "customer_email": "alice@example.com",
                "issue_description": "I ordered a laptop yesterday but haven't received a confirmation email. My credit card was charged. Order should be for Alice Johnson.",
            }

            response = await client.post(
                "/customer_support/execute", json=support_request, timeout=60.0
            )

            assert response.status_code == 200
            ticket = response.json()

            # Verify ticket creation
            assert "ticket_id" in ticket
            assert ticket["category"] in ["order_issue", "payment_issue"]
            assert ticket["priority"] in ["high", "medium", "low"]

            # Check AI response
            assert len(ticket["ai_response"]) > 50

            # Verify customer was identified (Alice is in test data)
            assert ticket["customer_id"] == "CUST001"

    @pytest.mark.asyncio
    async def test_concurrent_user_flows(self, gateway_with_workflows):
        """Test multiple concurrent user flows."""
        async with httpx.AsyncClient(base_url=BASE_URL) as client:
            # Simulate multiple users doing different things
            tasks = []

            # 5 users placing orders
            for i in range(5):
                order_task = client.post(
                    "/ecommerce/execute",
                    json={
                        "customer_email": f"concurrent_{i}@example.com",
                        "items": [{"product_id": "PROD001", "quantity": 1}],
                    },
                )
                tasks.append(order_task)

            # 3 users running analytics
            for i in range(3):
                analytics_task = client.post(
                    "/analytics/execute", json={"time_range": "7 days"}
                )
                tasks.append(analytics_task)

            # 2 users submitting support tickets
            for i in range(2):
                support_task = client.post(
                    "/customer_support/execute",
                    json={
                        "customer_email": f"support_{i}@example.com",
                        "issue_description": f"Test issue {i}",
                    },
                )
                tasks.append(support_task)

            # Execute all concurrently
            responses = await asyncio.gather(*tasks, return_exceptions=True)

            # Verify all succeeded
            success_count = sum(
                1
                for r in responses
                if not isinstance(r, Exception) and r.status_code == 200
            )

            assert success_count >= 8  # Most should succeed

    @pytest.mark.asyncio
    async def test_idempotency_in_user_flow(self, gateway_with_workflows):
        """Test idempotency in real user scenarios."""
        async with httpx.AsyncClient(base_url=BASE_URL) as client:
            idempotency_key = f"user-order-{uuid.uuid4()}"

            order_request = {
                "customer_email": "idempotent@example.com",
                "items": [{"product_id": "PROD003", "quantity": 1}],
            }

            # First request
            response1 = await client.post(
                "/ecommerce/execute",
                json=order_request,
                headers={"Idempotency-Key": idempotency_key},
            )

            assert response1.status_code == 200
            order1 = response1.json()

            # Duplicate request (user clicked twice)
            response2 = await client.post(
                "/ecommerce/execute",
                json=order_request,
                headers={"Idempotency-Key": idempotency_key},
            )

            assert response2.status_code == 200
            order2 = response2.json()

            # Should be the same order
            assert order1["order_id"] == order2["order_id"]
            assert response2.headers.get("X-Cached-Response") == "true"

    @pytest.mark.asyncio
    async def test_durability_monitoring(self, gateway_with_workflows):
        """Test durability monitoring and projections."""
        async with httpx.AsyncClient(base_url=BASE_URL) as client:
            # Execute several workflows
            for i in range(5):
                await client.post(
                    "/ecommerce/execute",
                    json={
                        "customer_email": f"monitor_{i}@example.com",
                        "items": [{"product_id": "PROD001", "quantity": 1}],
                    },
                )

            # Check durability status
            status_response = await client.get("/durability/status")
            assert status_response.status_code == 200

            status = status_response.json()
            assert status["enabled"] is True
            assert status["active_requests"] >= 0
            assert status["checkpoint_stats"]["save_count"] > 0
            assert status["deduplication_stats"]["hit_count"] >= 0
            assert status["event_store_stats"]["event_count"] > 0

            # Check projections
            perf_response = await client.get(
                "/durability/projections/performance_metrics"
            )
            assert perf_response.status_code == 200

            metrics = perf_response.json()["state"]
            assert metrics["total_requests"] >= 5
            assert metrics["completed_requests"] >= 0
