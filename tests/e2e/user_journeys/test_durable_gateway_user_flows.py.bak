"""End-to-end user flow tests for Durable Gateway.

These tests simulate real user scenarios including:
- E-commerce order processing with payment failures and retries
- Data analysis with AI-generated insights
- Long-running batch processing with resume capability
- Multi-step workflows with human-in-the-loop approvals
"""

import asyncio
import json
import random
import uuid
from datetime import datetime, timedelta
from typing import Any, Dict, List

import httpx
import pytest
import pytest_asyncio

from kailash.middleware.gateway.durable_gateway import DurableAPIGateway
from kailash.nodes.ai import LLMAgentNode
from kailash.nodes.api import HTTPRequestNode
from kailash.nodes.code import PythonCodeNode
from kailash.nodes.data.workflow_connection_pool import WorkflowConnectionPool
from kailash.nodes.logic import SwitchNode
from kailash.workflow import Workflow, WorkflowBuilder

# Test configuration
TEST_PORT = 8002
BASE_URL = f"http://localhost:{TEST_PORT}"

POSTGRES_CONFIG = {
    "database_type": "postgresql",
    "host": "localhost",
    "port": 5433,
    "database": "kailash_test",
    "user": "admin",
    "password": "admin",
}


class TestUserFlows:
    """User flow tests for real-world scenarios."""

    @pytest.fixture
    async def test_data_setup(self):
        """Set up test data and environment."""
        pool = WorkflowConnectionPool(
            name="test_data_setup",
            **POSTGRES_CONFIG,
            min_connections=2,
            max_connections=10,
        )

        await pool.process({"operation": "initialize"})

        # Create comprehensive test schema
        conn = await pool.process({"operation": "acquire"})
        conn_id = conn["connection_id"]

        try:
            # E-commerce schema
            await self._create_ecommerce_schema(pool, conn_id)

            # Analytics schema
            await self._create_analytics_schema(pool, conn_id)

            # Batch processing schema
            await self._create_batch_schema(pool, conn_id)

            # Insert sample data
            await self._insert_sample_data(pool, conn_id)

        finally:
            await pool.process({"operation": "release", "connection_id": conn_id})

        yield pool

    async def _create_ecommerce_schema(self, pool, conn_id):
        """Create e-commerce tables."""
        tables = [
            """DROP TABLE IF EXISTS customers CASCADE""",
            """DROP TABLE IF EXISTS products CASCADE""",
            """DROP TABLE IF EXISTS orders CASCADE""",
            """DROP TABLE IF EXISTS order_items CASCADE""",
            """DROP TABLE IF EXISTS payments CASCADE""",
            """DROP TABLE IF EXISTS inventory CASCADE""",
            """CREATE TABLE customers (
                customer_id VARCHAR(50) PRIMARY KEY,
                name VARCHAR(100),
                email VARCHAR(100) UNIQUE,
                tier VARCHAR(20) DEFAULT 'standard',
                total_spent DECIMAL(10,2) DEFAULT 0,
                created_at TIMESTAMP DEFAULT NOW()
            )""",
            """CREATE TABLE products (
                product_id VARCHAR(50) PRIMARY KEY,
                name VARCHAR(100),
                category VARCHAR(50),
                price DECIMAL(10,2),
                cost DECIMAL(10,2),
                description TEXT,
                created_at TIMESTAMP DEFAULT NOW()
            )""",
            """CREATE TABLE inventory (
                product_id VARCHAR(50) REFERENCES products(product_id),
                quantity INTEGER DEFAULT 0,
                reserved INTEGER DEFAULT 0,
                last_updated TIMESTAMP DEFAULT NOW(),
                PRIMARY KEY (product_id)
            )""",
            """CREATE TABLE orders (
                order_id VARCHAR(50) PRIMARY KEY,
                customer_id VARCHAR(50) REFERENCES customers(customer_id),
                total_amount DECIMAL(10,2),
                status VARCHAR(20),
                payment_status VARCHAR(20),
                created_at TIMESTAMP DEFAULT NOW(),
                updated_at TIMESTAMP DEFAULT NOW()
            )""",
            """CREATE TABLE order_items (
                item_id SERIAL PRIMARY KEY,
                order_id VARCHAR(50) REFERENCES orders(order_id),
                product_id VARCHAR(50) REFERENCES products(product_id),
                quantity INTEGER,
                unit_price DECIMAL(10,2),
                total_price DECIMAL(10,2)
            )""",
            """CREATE TABLE payments (
                payment_id VARCHAR(50) PRIMARY KEY,
                order_id VARCHAR(50) REFERENCES orders(order_id),
                amount DECIMAL(10,2),
                method VARCHAR(20),
                status VARCHAR(20),
                attempt_count INTEGER DEFAULT 1,
                created_at TIMESTAMP DEFAULT NOW()
            )""",
        ]

        for query in tables:
            await pool.process(
                {
                    "operation": "execute",
                    "connection_id": conn_id,
                    "query": query,
                    "fetch_mode": "one",
                }
            )

    async def _create_analytics_schema(self, pool, conn_id):
        """Create analytics tables."""
        tables = [
            """DROP TABLE IF EXISTS user_events CASCADE""",
            """DROP TABLE IF EXISTS analytics_reports CASCADE""",
            """CREATE TABLE user_events (
                event_id SERIAL PRIMARY KEY,
                user_id VARCHAR(50),
                event_type VARCHAR(50),
                event_data JSONB,
                timestamp TIMESTAMP DEFAULT NOW()
            )""",
            """CREATE TABLE analytics_reports (
                report_id VARCHAR(50) PRIMARY KEY,
                report_type VARCHAR(50),
                parameters JSONB,
                results JSONB,
                ai_insights TEXT,
                created_at TIMESTAMP DEFAULT NOW()
            )""",
        ]

        for query in tables:
            await pool.process(
                {
                    "operation": "execute",
                    "connection_id": conn_id,
                    "query": query,
                    "fetch_mode": "one",
                }
            )

    async def _create_batch_schema(self, pool, conn_id):
        """Create batch processing tables."""
        tables = [
            """DROP TABLE IF EXISTS batch_jobs CASCADE""",
            """DROP TABLE IF EXISTS batch_items CASCADE""",
            """CREATE TABLE batch_jobs (
                job_id VARCHAR(50) PRIMARY KEY,
                job_type VARCHAR(50),
                total_items INTEGER,
                processed_items INTEGER DEFAULT 0,
                status VARCHAR(20),
                checkpoint_data JSONB,
                created_at TIMESTAMP DEFAULT NOW(),
                updated_at TIMESTAMP DEFAULT NOW()
            )""",
            """CREATE TABLE batch_items (
                item_id SERIAL PRIMARY KEY,
                job_id VARCHAR(50) REFERENCES batch_jobs(job_id),
                item_data JSONB,
                status VARCHAR(20) DEFAULT 'pending',
                result JSONB,
                processed_at TIMESTAMP
            )""",
        ]

        for query in tables:
            await pool.process(
                {
                    "operation": "execute",
                    "connection_id": conn_id,
                    "query": query,
                    "fetch_mode": "one",
                }
            )

    async def _insert_sample_data(self, pool, conn_id):
        """Insert sample data for testing."""
        # Customers
        customers = [
            ("CUST001", "Alice Johnson", "alice@example.com", "premium", 5000),
            ("CUST002", "Bob Smith", "bob@example.com", "standard", 1000),
            ("CUST003", "Carol White", "carol@example.com", "premium", 8000),
            ("CUST004", "David Brown", "david@example.com", "standard", 500),
            ("CUST005", "Eve Davis", "eve@example.com", "vip", 15000),
        ]

        for customer in customers:
            await pool.process(
                {
                    "operation": "execute",
                    "connection_id": conn_id,
                    "query": """
                    INSERT INTO customers (customer_id, name, email, tier, total_spent)
                    VALUES ($1, $2, $3, $4, $5)
                    ON CONFLICT (customer_id) DO NOTHING
                """,
                    "params": customer,
                    "fetch_mode": "one",
                }
            )

        # Products
        products = [
            (
                "PROD001",
                "Laptop Pro",
                "Electronics",
                1299.99,
                900.00,
                "High-performance laptop",
            ),
            (
                "PROD002",
                "Wireless Mouse",
                "Electronics",
                49.99,
                25.00,
                "Ergonomic wireless mouse",
            ),
            (
                "PROD003",
                "Office Chair",
                "Furniture",
                399.99,
                200.00,
                "Comfortable office chair",
            ),
            (
                "PROD004",
                "Standing Desk",
                "Furniture",
                599.99,
                350.00,
                "Adjustable standing desk",
            ),
            (
                "PROD005",
                "Monitor 4K",
                "Electronics",
                499.99,
                300.00,
                "4K Ultra HD monitor",
            ),
        ]

        for product in products:
            await pool.process(
                {
                    "operation": "execute",
                    "connection_id": conn_id,
                    "query": """
                    INSERT INTO products (product_id, name, category, price, cost, description)
                    VALUES ($1, $2, $3, $4, $5, $6)
                    ON CONFLICT (product_id) DO NOTHING
                """,
                    "params": product,
                    "fetch_mode": "one",
                }
            )

        # Inventory
        for i, (product_id, _, _, _, _, _) in enumerate(products):
            quantity = random.randint(10, 100)
            await pool.process(
                {
                    "operation": "execute",
                    "connection_id": conn_id,
                    "query": """
                    INSERT INTO inventory (product_id, quantity, reserved)
                    VALUES ($1, $2, 0)
                    ON CONFLICT (product_id) DO UPDATE SET quantity = EXCLUDED.quantity
                """,
                    "params": [product_id, quantity],
                    "fetch_mode": "one",
                }
            )

    @pytest.fixture
    async def gateway_with_workflows(self, test_data_setup):
        """Create gateway with comprehensive workflows."""
        gateway = DurableAPIGateway(
            title="User Flow Test Gateway",
            port=TEST_PORT,
            enable_durability=True,
            durability_opt_in=False,
        )

        # Register all workflows
        await self._register_all_workflows(gateway, test_data_setup)

        # Start gateway
        gateway_task = asyncio.create_task(gateway.run_async())
        await asyncio.sleep(1)

        yield gateway

        gateway_task.cancel()
        await gateway.close()

    async def _register_all_workflows(self, gateway, pool):
        """Register all test workflows."""
        # 1. E-commerce order workflow with payment retry
        order_workflow = await self._create_ecommerce_workflow(pool)
        gateway.register_workflow("ecommerce", order_workflow)

        # 2. Customer analytics workflow
        analytics_workflow = await self._create_analytics_workflow(pool)
        gateway.register_workflow("analytics", analytics_workflow)

        # 3. Batch processing workflow
        batch_workflow = await self._create_batch_workflow(pool)
        gateway.register_workflow("batch_processing", batch_workflow)

        # 4. Customer support workflow
        support_workflow = await self._create_support_workflow(pool)
        gateway.register_workflow("customer_support", support_workflow)

    async def _create_ecommerce_workflow(self, pool) -> Workflow:
        """Create comprehensive e-commerce workflow."""
        workflow = WorkflowBuilder("ecommerce_flow")

        # 1. Validate customer
        workflow.add_node(
            "validate_customer",
            "PythonCodeNode",
            {
                "code": """
pool = inputs["pool"]
customer_email = inputs["customer_email"]

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    result = await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": "SELECT * FROM customers WHERE email = $1",
        "params": [customer_email],
        "fetch_mode": "one"
    })

    if not result["data"]:
        # Create new customer
        customer_id = f"CUST{str(uuid.uuid4())[:8]}"
        await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                INSERT INTO customers (customer_id, name, email)
                VALUES ($1, $2, $3)
                RETURNING *
            ''',
            "params": [customer_id, inputs.get("customer_name", "Guest"), customer_email],
            "fetch_mode": "one"
        })
        customer = {"customer_id": customer_id, "tier": "standard", "new_customer": True}
    else:
        customer = result["data"]
        customer["new_customer"] = False

    result = {"customer": customer, "validated": True}

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "imports": ["uuid"],
                "inputs": {"pool": pool},
            },
        )

        # 2. Check inventory
        workflow.add_node(
            "check_inventory",
            "PythonCodeNode",
            {
                "code": """
pool = inputs["pool"]
items = inputs["items"]

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    available_items = []
    unavailable_items = []

    for item in items:
        result = await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                SELECT i.*, p.name, p.price
                FROM inventory i
                JOIN products p ON i.product_id = p.product_id
                WHERE i.product_id = $1
            ''',
            "params": [item["product_id"]],
            "fetch_mode": "one"
        })

        if result["data"] and result["data"]["quantity"] - result["data"]["reserved"] >= item["quantity"]:
            available_items.append({
                **item,
                "unit_price": float(result["data"]["price"]),
                "product_name": result["data"]["name"]
            })
        else:
            unavailable_items.append(item)

    result = {
        "available_items": available_items,
        "unavailable_items": unavailable_items,
        "all_available": len(unavailable_items) == 0
    }

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "inputs": {"pool": pool},
            },
        )

        # 3. Reserve inventory
        workflow.add_node(
            "reserve_inventory",
            "PythonCodeNode",
            {
                "code": """
pool = inputs["pool"]
items = inputs["available_items"]
order_id = inputs["order_id"]

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    # Start transaction
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": "BEGIN",
        "fetch_mode": "one"
    })

    reserved_items = []
    for item in items:
        # Reserve inventory
        await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                UPDATE inventory
                SET reserved = reserved + $1
                WHERE product_id = $2 AND quantity - reserved >= $1
            ''',
            "params": [item["quantity"], item["product_id"]],
            "fetch_mode": "one"
        })

        reserved_items.append({
            "product_id": item["product_id"],
            "quantity": item["quantity"],
            "reserved_for": order_id
        })

    # Commit transaction
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": "COMMIT",
        "fetch_mode": "one"
    })

    result = {"reserved_items": reserved_items, "reservation_success": True}

except Exception as e:
    # Rollback on error
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": "ROLLBACK",
        "fetch_mode": "one"
    })
    result = {"reservation_success": False, "error": str(e)}

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "inputs": {"pool": pool},
            },
        )

        # 4. Create order
        workflow.add_node(
            "create_order",
            "PythonCodeNode",
            {
                "code": """
import uuid
from datetime import datetime

customer = inputs["customer"]
items = inputs["items"]

order_id = f"ORD-{datetime.now().strftime('%Y%m%d')}-{str(uuid.uuid4())[:8]}"
total_amount = sum(item["quantity"] * item["unit_price"] for item in items)

# Apply tier discount
discounts = {"vip": 0.15, "premium": 0.10, "standard": 0.0}
discount_rate = discounts.get(customer.get("tier", "standard"), 0.0)
discount_amount = total_amount * discount_rate
final_amount = total_amount - discount_amount

result = {
    "order_id": order_id,
    "customer_id": customer["customer_id"],
    "items": items,
    "subtotal": total_amount,
    "discount_rate": discount_rate,
    "discount_amount": discount_amount,
    "total_amount": final_amount,
    "status": "pending_payment"
}
""",
                "imports": ["uuid", "datetime"],
            },
        )

        # 5. Save order
        workflow.add_node(
            "save_order",
            "PythonCodeNode",
            {
                "code": """
pool = inputs["pool"]
order = inputs["order"]

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    # Insert order
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": '''
            INSERT INTO orders (order_id, customer_id, total_amount, status, payment_status)
            VALUES ($1, $2, $3, $4, $5)
        ''',
        "params": [
            order["order_id"],
            order["customer_id"],
            order["total_amount"],
            order["status"],
            "pending"
        ],
        "fetch_mode": "one"
    })

    # Insert order items
    for item in order["items"]:
        await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                INSERT INTO order_items (order_id, product_id, quantity, unit_price, total_price)
                VALUES ($1, $2, $3, $4, $5)
            ''',
            "params": [
                order["order_id"],
                item["product_id"],
                item["quantity"],
                item["unit_price"],
                item["quantity"] * item["unit_price"]
            ],
            "fetch_mode": "one"
        })

    result = {"order_saved": True, "order_id": order["order_id"]}

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "inputs": {"pool": pool},
            },
        )

        # 6. Process payment with retry logic
        workflow.add_node(
            "process_payment",
            "PythonCodeNode",
            {
                "code": """
import random
import asyncio

pool = inputs["pool"]
order_id = inputs["order_id"]
amount = inputs["amount"]
payment_method = inputs.get("payment_method", "credit_card")
attempt = inputs.get("attempt", 1)

# Simulate payment processing
await asyncio.sleep(0.5)

# Success rate based on amount and attempt
if amount < 100:
    success_rate = 0.95
elif amount < 1000:
    success_rate = 0.90
else:
    success_rate = 0.85

# Higher success rate on retries (payment provider fixed issue)
if attempt > 1:
    success_rate = min(0.98, success_rate + 0.05 * attempt)

success = random.random() < success_rate

payment_id = f"PAY-{order_id}-{attempt}"

# Save payment attempt
conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": '''
            INSERT INTO payments (payment_id, order_id, amount, method, status, attempt_count)
            VALUES ($1, $2, $3, $4, $5, $6)
        ''',
        "params": [
            payment_id,
            order_id,
            amount,
            payment_method,
            "success" if success else "failed",
            attempt
        ],
        "fetch_mode": "one"
    })

    result = {
        "payment_id": payment_id,
        "success": success,
        "amount": amount,
        "attempt": attempt,
        "reason": None if success else "Payment declined by processor"
    }

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "imports": ["random", "asyncio"],
                "inputs": {"pool": pool},
            },
        )

        # 7. Payment retry decision
        workflow.add_node(
            "payment_retry_decision",
            "SwitchNode",
            {"name": "payment_retry", "condition_path": "payment_result.success"},
        )

        # 8. Finalize order
        workflow.add_node(
            "finalize_order",
            "PythonCodeNode",
            {
                "code": """
pool = inputs["pool"]
order_id = inputs["order_id"]
payment_result = inputs["payment_result"]

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    # Update order status
    status = "completed" if payment_result["success"] else "payment_failed"
    payment_status = "paid" if payment_result["success"] else "failed"

    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": '''
            UPDATE orders
            SET status = $1, payment_status = $2, updated_at = NOW()
            WHERE order_id = $3
        ''',
        "params": [status, payment_status, order_id],
        "fetch_mode": "one"
    })

    if payment_result["success"]:
        # Finalize inventory
        await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                UPDATE inventory i
                SET quantity = quantity - oi.quantity,
                    reserved = reserved - oi.quantity
                FROM order_items oi
                WHERE i.product_id = oi.product_id
                AND oi.order_id = $1
            ''',
            "params": [order_id],
            "fetch_mode": "one"
        })

        # Update customer total spent
        await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                UPDATE customers c
                SET total_spent = total_spent + o.total_amount
                FROM orders o
                WHERE c.customer_id = o.customer_id
                AND o.order_id = $1
            ''',
            "params": [order_id],
            "fetch_mode": "one"
        })
    else:
        # Release reserved inventory
        await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                UPDATE inventory i
                SET reserved = reserved - oi.quantity
                FROM order_items oi
                WHERE i.product_id = oi.product_id
                AND oi.order_id = $1
            ''',
            "params": [order_id],
            "fetch_mode": "one"
        })

    result = {
        "order_id": order_id,
        "final_status": status,
        "payment_status": payment_status,
        "success": payment_result["success"]
    }

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "inputs": {"pool": pool},
            },
        )

        # Connect workflow
        workflow.add_connection(
            "validate_customer", "check_inventory", "result.customer", "customer"
        )
        workflow.add_connection(
            "check_inventory",
            "reserve_inventory",
            "result.available_items",
            "available_items",
        )
        workflow.add_connection(
            "create_order", "reserve_inventory", "result.order_id", "order_id"
        )
        workflow.add_connection(
            "validate_customer", "create_order", "result.customer", "customer"
        )
        workflow.add_connection(
            "check_inventory", "create_order", "result.available_items", "items"
        )
        workflow.add_connection("create_order", "save_order", "result", "order")
        workflow.add_connection(
            "save_order", "process_payment", "result.order_id", "order_id"
        )
        workflow.add_connection(
            "create_order", "process_payment", "result.total_amount", "amount"
        )
        workflow.add_connection(
            "process_payment", "payment_retry_decision", "result", "payment_result"
        )

        # Success path
        workflow.add_connection(
            "payment_retry_decision",
            "finalize_order",
            condition_value=True,
            mappings={"payment_result": "payment_result"},
        )
        workflow.add_connection(
            "save_order",
            "finalize_order",
            "result.order_id",
            "order_id",
            condition_source="payment_retry_decision",
            condition_value=True,
        )

        # Retry path (simplified - would have more complex retry logic)
        workflow.add_connection(
            "payment_retry_decision",
            "finalize_order",
            condition_value=False,
            mappings={"payment_result": "payment_result"},
        )
        workflow.add_connection(
            "save_order",
            "finalize_order",
            "result.order_id",
            "order_id",
            condition_source="payment_retry_decision",
            condition_value=False,
        )

        return workflow.build()

    async def _create_analytics_workflow(self, pool) -> Workflow:
        """Create customer analytics workflow with AI insights."""
        workflow = WorkflowBuilder("analytics_flow")

        # Fetch customer data
        workflow.add_node(
            "fetch_customer_data",
            "PythonCodeNode",
            {
                "code": """
pool = inputs["pool"]
time_range = inputs.get("time_range", "7 days")
segment = inputs.get("segment", "all")

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    # Customer summary
    customer_query = '''
        SELECT
            COUNT(DISTINCT c.customer_id) as total_customers,
            COUNT(DISTINCT CASE WHEN c.tier = 'vip' THEN c.customer_id END) as vip_customers,
            COUNT(DISTINCT CASE WHEN c.tier = 'premium' THEN c.customer_id END) as premium_customers,
            AVG(c.total_spent) as avg_lifetime_value,
            MAX(c.total_spent) as max_lifetime_value
        FROM customers c
    '''

    if segment != "all":
        customer_query += f" WHERE c.tier = $1"
        params = [segment]
    else:
        params = []

    customer_result = await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": customer_query,
        "params": params,
        "fetch_mode": "one"
    })

    # Order analytics
    order_query = f'''
        SELECT
            COUNT(*) as total_orders,
            SUM(total_amount) as total_revenue,
            AVG(total_amount) as avg_order_value,
            COUNT(DISTINCT customer_id) as unique_customers,
            COUNT(CASE WHEN status = 'completed' THEN 1 END) as completed_orders,
            COUNT(CASE WHEN status = 'payment_failed' THEN 1 END) as failed_orders
        FROM orders
        WHERE created_at >= NOW() - INTERVAL '{time_range}'
    '''

    order_result = await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": order_query,
        "fetch_mode": "one"
    })

    # Top products
    product_query = f'''
        SELECT
            p.name as product_name,
            p.category,
            COUNT(oi.item_id) as times_ordered,
            SUM(oi.quantity) as total_quantity,
            SUM(oi.total_price) as total_revenue
        FROM order_items oi
        JOIN products p ON oi.product_id = p.product_id
        JOIN orders o ON oi.order_id = o.order_id
        WHERE o.created_at >= NOW() - INTERVAL '{time_range}'
        GROUP BY p.product_id, p.name, p.category
        ORDER BY total_revenue DESC
        LIMIT 10
    '''

    product_result = await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": product_query,
        "fetch_mode": "all"
    })

    result = {
        "customer_summary": customer_result["data"],
        "order_summary": order_result["data"],
        "top_products": product_result["data"],
        "time_range": time_range,
        "segment": segment
    }

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "inputs": {"pool": pool},
            },
        )

        # Generate AI insights
        workflow.add_node(
            "generate_insights",
            "LLMAgentNode",
            {
                "name": "analytics_ai",
                "model": "llama2",
                "api_base": "http://localhost:11434",
                "system_prompt": """You are a business intelligence analyst specializing in e-commerce.
Analyze the provided data and generate actionable insights.

Focus on:
1. Customer behavior patterns and segmentation opportunities
2. Revenue trends and growth opportunities
3. Product performance and inventory recommendations
4. Risk factors and areas needing attention
5. Specific, actionable recommendations

Format your response as a structured analysis with clear sections.""",
                "prompt": """Analyze this e-commerce business data for the period: {{time_range}}

Customer Summary:
- Total Customers: {{customer_summary.total_customers}}
- VIP Customers: {{customer_summary.vip_customers}}
- Premium Customers: {{customer_summary.premium_customers}}
- Average Lifetime Value: ${{customer_summary.avg_lifetime_value}}
- Max Lifetime Value: ${{customer_summary.max_lifetime_value}}

Order Summary:
- Total Orders: {{order_summary.total_orders}}
- Total Revenue: ${{order_summary.total_revenue}}
- Average Order Value: ${{order_summary.avg_order_value}}
- Unique Customers: {{order_summary.unique_customers}}
- Completed Orders: {{order_summary.completed_orders}}
- Failed Orders: {{order_summary.failed_orders}}

Top Products:
{{#each top_products}}
- {{product_name}} ({{category}}): {{times_ordered}} orders, ${{total_revenue}} revenue
{{/each}}

Provide detailed analysis with specific recommendations.""",
                "temperature": 0.7,
                "max_tokens": 1000,
            },
        )

        # Create report
        workflow.add_node(
            "create_report",
            "PythonCodeNode",
            {
                "code": """
import json
from datetime import datetime

pool = inputs["pool"]
data = inputs["data"]
insights = inputs["insights"]

report_id = f"RPT-{datetime.now().strftime('%Y%m%d%H%M%S')}"

# Structure the report
report = {
    "report_id": report_id,
    "generated_at": datetime.now().isoformat(),
    "parameters": {
        "time_range": data["time_range"],
        "segment": data["segment"]
    },
    "data_summary": {
        "customers": data["customer_summary"],
        "orders": data["order_summary"],
        "top_products": data["top_products"]
    },
    "ai_insights": insights.get("response", "Analysis not available"),
    "metrics": {
        "conversion_rate": (
            data["order_summary"]["unique_customers"] /
            data["customer_summary"]["total_customers"] * 100
            if data["customer_summary"]["total_customers"] > 0 else 0
        ),
        "order_success_rate": (
            data["order_summary"]["completed_orders"] /
            data["order_summary"]["total_orders"] * 100
            if data["order_summary"]["total_orders"] > 0 else 0
        )
    }
}

# Save report
conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": '''
            INSERT INTO analytics_reports (report_id, report_type, parameters, results, ai_insights)
            VALUES ($1, $2, $3, $4, $5)
        ''',
        "params": [
            report_id,
            "customer_analytics",
            json.dumps({"time_range": data["time_range"], "segment": data["segment"]}),
            json.dumps(report["data_summary"]),
            report["ai_insights"]
        ],
        "fetch_mode": "one"
    })

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })

result = report
""",
                "imports": ["json", "datetime"],
                "inputs": {"pool": pool},
            },
        )

        # Connect workflow
        workflow.add_connection(
            "fetch_customer_data", "generate_insights", "result", "data"
        )
        workflow.add_connection(
            "fetch_customer_data", "create_report", "result", "data"
        )
        workflow.add_connection(
            "generate_insights", "create_report", "result", "insights"
        )

        return workflow.build()

    async def _create_batch_workflow(self, pool) -> Workflow:
        """Create batch processing workflow with checkpoint/resume."""
        workflow = WorkflowBuilder("batch_processor")

        # Initialize batch job
        workflow.add_node(
            "init_batch",
            "PythonCodeNode",
            {
                "code": """
import uuid
from datetime import datetime

job_type = inputs.get("job_type", "data_migration")
items = inputs.get("items", [])
batch_size = inputs.get("batch_size", 10)

job_id = f"BATCH-{datetime.now().strftime('%Y%m%d')}-{str(uuid.uuid4())[:8]}"

# Save job metadata
pool = inputs["pool"]
conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    # Create batch job
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": '''
            INSERT INTO batch_jobs (job_id, job_type, total_items, status)
            VALUES ($1, $2, $3, $4)
        ''',
        "params": [job_id, job_type, len(items), "initialized"],
        "fetch_mode": "one"
    })

    # Insert batch items
    for i, item in enumerate(items):
        await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                INSERT INTO batch_items (job_id, item_data)
                VALUES ($1, $2)
            ''',
            "params": [job_id, json.dumps(item)],
            "fetch_mode": "one"
        })

    result = {
        "job_id": job_id,
        "total_items": len(items),
        "batch_size": batch_size,
        "status": "ready"
    }

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "imports": ["uuid", "datetime", "json"],
                "inputs": {"pool": pool},
            },
        )

        # Process batches
        workflow.add_node(
            "process_batches",
            "PythonCodeNode",
            {
                "code": """
import asyncio
import random
import json

pool = inputs["pool"]
job_id = inputs["job_id"]
batch_size = inputs["batch_size"]

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    # Update job status
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": "UPDATE batch_jobs SET status = 'processing' WHERE job_id = $1",
        "params": [job_id],
        "fetch_mode": "one"
    })

    processed_count = 0
    failed_count = 0

    while True:
        # Get next batch of unprocessed items
        batch_result = await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                SELECT item_id, item_data
                FROM batch_items
                WHERE job_id = $1 AND status = 'pending'
                LIMIT $2
            ''',
            "params": [job_id, batch_size],
            "fetch_mode": "all"
        })

        items = batch_result["data"]
        if not items:
            break  # No more items to process

        # Process batch
        for item in items:
            await asyncio.sleep(0.1)  # Simulate processing

            # Random success/failure for testing
            success = random.random() > 0.1

            if success:
                result_data = {
                    "processed": True,
                    "value": random.randint(100, 1000)
                }
                status = "completed"
                processed_count += 1
            else:
                result_data = {"error": "Processing failed"}
                status = "failed"
                failed_count += 1

            # Update item status
            await pool.process({
                "operation": "execute",
                "connection_id": conn_id,
                "query": '''
                    UPDATE batch_items
                    SET status = $1, result = $2, processed_at = NOW()
                    WHERE item_id = $3
                ''',
                "params": [status, json.dumps(result_data), item["item_id"]],
                "fetch_mode": "one"
            })

        # Update job progress
        await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                UPDATE batch_jobs
                SET processed_items = $1, updated_at = NOW()
                WHERE job_id = $2
            ''',
            "params": [processed_count + failed_count, job_id],
            "fetch_mode": "one"
        })

        # Checkpoint every N items
        if (processed_count + failed_count) % 20 == 0:
            checkpoint_data = {
                "processed": processed_count,
                "failed": failed_count,
                "last_item_id": items[-1]["item_id"]
            }

            await pool.process({
                "operation": "execute",
                "connection_id": conn_id,
                "query": '''
                    UPDATE batch_jobs
                    SET checkpoint_data = $1
                    WHERE job_id = $2
                ''',
                "params": [json.dumps(checkpoint_data), job_id],
                "fetch_mode": "one"
            })

    # Update final status
    final_status = "completed" if failed_count == 0 else "completed_with_errors"
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": '''
            UPDATE batch_jobs
            SET status = $1, processed_items = $2, updated_at = NOW()
            WHERE job_id = $3
        ''',
        "params": [final_status, processed_count + failed_count, job_id],
        "fetch_mode": "one"
    })

    result = {
        "job_id": job_id,
        "processed": processed_count,
        "failed": failed_count,
        "status": final_status
    }

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "imports": ["asyncio", "random", "json"],
                "inputs": {"pool": pool},
            },
        )

        # Generate summary
        workflow.add_node(
            "generate_summary",
            "PythonCodeNode",
            {
                "code": """
pool = inputs["pool"]
job_id = inputs["job_id"]
process_result = inputs["process_result"]

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    # Get detailed results
    summary_result = await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": '''
            SELECT
                COUNT(*) as total_items,
                COUNT(CASE WHEN status = 'completed' THEN 1 END) as successful,
                COUNT(CASE WHEN status = 'failed' THEN 1 END) as failed,
                COUNT(CASE WHEN status = 'pending' THEN 1 END) as pending,
                MIN(processed_at) as start_time,
                MAX(processed_at) as end_time
            FROM batch_items
            WHERE job_id = $1
        ''',
        "params": [job_id],
        "fetch_mode": "one"
    })

    summary = summary_result["data"]

    # Calculate duration
    if summary["start_time"] and summary["end_time"]:
        duration = (summary["end_time"] - summary["start_time"]).total_seconds()
    else:
        duration = 0

    result = {
        "job_id": job_id,
        "summary": {
            "total_items": summary["total_items"],
            "successful": summary["successful"],
            "failed": summary["failed"],
            "pending": summary["pending"],
            "success_rate": (
                summary["successful"] / summary["total_items"] * 100
                if summary["total_items"] > 0 else 0
            ),
            "duration_seconds": duration
        },
        "status": process_result["status"]
    }

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "inputs": {"pool": pool},
            },
        )

        # Connect workflow
        workflow.add_connection(
            "init_batch", "process_batches", "result", "batch_params"
        )
        workflow.add_connection(
            "init_batch", "process_batches", "result.job_id", "job_id"
        )
        workflow.add_connection(
            "init_batch", "process_batches", "result.batch_size", "batch_size"
        )
        workflow.add_connection(
            "process_batches", "generate_summary", "result", "process_result"
        )
        workflow.add_connection(
            "process_batches", "generate_summary", "result.job_id", "job_id"
        )

        return workflow.build()

    async def _create_support_workflow(self, pool) -> Workflow:
        """Create customer support workflow with AI assistance."""
        workflow = WorkflowBuilder("support_flow")

        # Categorize issue
        workflow.add_node(
            "categorize_issue",
            "LLMAgentNode",
            {
                "name": "support_categorizer",
                "model": "llama2",
                "api_base": "http://localhost:11434",
                "system_prompt": """You are a customer support categorization system.
Analyze the customer issue and categorize it into one of these categories:
- order_issue: Problems with orders (missing items, wrong items, damaged)
- payment_issue: Payment failures, refunds, billing questions
- technical_issue: Website/app problems, login issues
- product_question: Questions about products, availability
- general_inquiry: Other general questions

Also determine the priority:
- high: Urgent issues affecting order completion or significant problems
- medium: Important but not urgent issues
- low: General questions or minor issues

Respond with JSON format: {"category": "...", "priority": "...", "summary": "..."}""",
                "prompt": "Customer issue: {{issue_description}}",
                "temperature": 0.3,
                "max_tokens": 200,
            },
        )

        # Look up customer history
        workflow.add_node(
            "lookup_customer",
            "PythonCodeNode",
            {
                "code": """
pool = inputs["pool"]
customer_email = inputs["customer_email"]

conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    # Get customer info
    customer_result = await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": "SELECT * FROM customers WHERE email = $1",
        "params": [customer_email],
        "fetch_mode": "one"
    })

    if customer_result["data"]:
        customer = customer_result["data"]

        # Get recent orders
        orders_result = await pool.process({
            "operation": "execute",
            "connection_id": conn_id,
            "query": '''
                SELECT order_id, total_amount, status, created_at
                FROM orders
                WHERE customer_id = $1
                ORDER BY created_at DESC
                LIMIT 5
            ''',
            "params": [customer["customer_id"]],
            "fetch_mode": "all"
        })

        result = {
            "customer": customer,
            "recent_orders": orders_result["data"],
            "is_vip": customer.get("tier") in ["vip", "premium"]
        }
    else:
        result = {
            "customer": None,
            "recent_orders": [],
            "is_vip": False
        }

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })
""",
                "inputs": {"pool": pool},
            },
        )

        # Generate AI response
        workflow.add_node(
            "generate_response",
            "LLMAgentNode",
            {
                "name": "support_responder",
                "model": "llama2",
                "api_base": "http://localhost:11434",
                "system_prompt": """You are a helpful customer support agent.
Use the customer information and issue details to provide a personalized response.
Be empathetic, professional, and solution-oriented.
If the customer is VIP or Premium, acknowledge their status.
Provide specific next steps or solutions.""",
                "prompt": """Issue Category: {{category}}
Priority: {{priority}}
Customer Status: {{#if is_vip}}VIP/Premium Customer{{else}}Standard Customer{{/if}}
Total Spent: ${{customer.total_spent}}

Recent Orders:
{{#each recent_orders}}
- Order {{order_id}}: ${{total_amount}} ({{status}})
{{/each}}

Customer Issue: {{issue_description}}

Provide a helpful response with specific solutions.""",
                "temperature": 0.7,
                "max_tokens": 500,
            },
        )

        # Create ticket
        workflow.add_node(
            "create_ticket",
            "PythonCodeNode",
            {
                "code": """
import uuid
from datetime import datetime
import json

ticket_id = f"TKT-{datetime.now().strftime('%Y%m%d')}-{str(uuid.uuid4())[:8]}"

categorization = json.loads(inputs.get("categorization", {}).get("response", "{}"))
customer_data = inputs["customer_data"]
ai_response = inputs["ai_response"]

ticket = {
    "ticket_id": ticket_id,
    "customer_email": inputs["customer_email"],
    "customer_id": customer_data["customer"]["customer_id"] if customer_data["customer"] else None,
    "category": categorization.get("category", "general_inquiry"),
    "priority": categorization.get("priority", "medium"),
    "issue_description": inputs["issue_description"],
    "ai_response": ai_response.get("response", ""),
    "status": "open",
    "created_at": datetime.now().isoformat()
}

# Log as event
pool = inputs["pool"]
conn = await pool.process({"operation": "acquire"})
conn_id = conn["connection_id"]

try:
    await pool.process({
        "operation": "execute",
        "connection_id": conn_id,
        "query": '''
            INSERT INTO user_events (user_id, event_type, event_data)
            VALUES ($1, $2, $3)
        ''',
        "params": [
            customer_data["customer"]["customer_id"] if customer_data["customer"] else "anonymous",
            "support_ticket_created",
            json.dumps(ticket)
        ],
        "fetch_mode": "one"
    })

finally:
    await pool.process({
        "operation": "release",
        "connection_id": conn_id
    })

result = ticket
""",
                "imports": ["uuid", "datetime", "json"],
                "inputs": {"pool": pool},
            },
        )

        # Connect workflow
        workflow.add_connection("categorize_issue", "lookup_customer")
        workflow.add_connection(
            "categorize_issue", "generate_response", "result", "categorization"
        )
        workflow.add_connection(
            "lookup_customer", "generate_response", "result", "customer_data"
        )
        workflow.add_connection(
            "categorize_issue", "create_ticket", "result", "categorization"
        )
        workflow.add_connection(
            "lookup_customer", "create_ticket", "result", "customer_data"
        )
        workflow.add_connection(
            "generate_response", "create_ticket", "result", "ai_response"
        )

        return workflow.build()

    @pytest.mark.asyncio
    async def test_ecommerce_order_flow(self, gateway_with_workflows):
        """Test complete e-commerce order flow with payment retry."""
        async with httpx.AsyncClient(base_url=BASE_URL) as client:
            # Place an order
            order_request = {
                "customer_email": "test@example.com",
                "customer_name": "Test User",
                "items": [
                    {"product_id": "PROD001", "quantity": 1},
                    {"product_id": "PROD002", "quantity": 2},
                ],
                "payment_method": "credit_card",
            }

            response = await client.post(
                "/ecommerce/execute", json=order_request, timeout=30.0
            )

            assert response.status_code == 200
            result = response.json()

            # Verify order was created
            assert "order_id" in result
            assert "final_status" in result

            # Check if payment succeeded or failed
            if result["final_status"] == "completed":
                assert result["payment_status"] == "paid"
            else:
                assert result["payment_status"] == "failed"

            # Verify durability
            request_id = response.headers.get("X-Request-ID")
            events_response = await client.get(
                f"/durability/requests/{request_id}/events"
            )

            events = events_response.json()
            assert events["event_count"] > 5  # Multiple checkpoints

    @pytest.mark.asyncio
