# Dependencies
node_modules/

# Python
__pycache__/

# Claude Code ephemeral agent worktrees (local, never committed)
.claude/worktrees/

# Claude Code local runtime state (sync markers, scheduler locks)
.claude/.coc-sync-marker
.claude/scheduled_tasks.lock

# ML runtime artifacts (experiment tracking, models)
.kailash_ml/
# CatBoost training artifacts (runtime output from ML tests)
catboost_info/
packages/*/catboost_info/

# DataFlow migration runtime history (generated per-run, never committed)
packages/kailash-dataflow/src/dataflow/migrations/performance_data/

# Self-certifying spec-coverage files are BANNED during audit mode.
# See .claude/rules/testing.md § Audit Mode Rules and
# .claude/skills/spec-compliance/SKILL.md.
# These files are ignored so they cannot accidentally be committed as "proof".
.spec-coverage
.spec-coverage.md
.spec-coverage-*.md
.test-results
.test-results.md

# Editable install symlinks (pip install -e creates these)
src/kailash/runtime.py
src/kailash/dataflow
src/kailash/enterprise
src/kailash/infra
src/kailash/kaizen
src/kailash/mcp
src/kailash/nexus
src/kailash/pact
src/kailash/py.typed
src/kailash/trust_plane
src/kailash/_kailash.cpython-*.so

# Test artifacts (mock objects leaking to filesystem)
<Mock *
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
!scripts/hooks/lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# IDE specific files
.idea/
.vscode/
.cursor/
*.swp
*.swo
.DS_Store
.jbeval/

# Testing
.pytest_cache/
.coverage.*
htmlcov/
test_*.db
test_shared_*.db
demo_mcp.db
mcp_registry.db
mcp_registry.json
test-env
*.db
*.db-wal
*.db-shm
default.db
# Stray SQLite files from tests that pass `:memory:<suffix>` as a non-URI
# database name. The literal string lands on disk as a real file. Real fix
# tracked separately (convert to URI shared-cache form per rules/patterns.md
# § SQLite Connection Management); this ignore prevents accidental commits.
:memory:*

# Kaizen checkpoints (local agent state)
.kaizen/

# Internal task tracking
todos/
**/todos/

# Claude Code session data (keep agents/skills/rules, ignore session artifacts)
.claude/learning/
.claude/settings.local.json
**/.claude/learning/

# Per-package proposal manifests are local-only; the canonical
# proposal lives at root .claude/.proposals/latest.yaml.
packages/*/.claude/.proposals/

# Per-package uv lockfiles are regenerated by `uv pip install -e .`
# and are not authoritative for releases. The root uv.lock is the
# single source of truth (per python-environment.md "uv.lock MUST
# be committed for applications, may gitignore for libraries").
packages/*/uv.lock

# Coverage artifacts
.coverage
**/.coverage

# Hypothesis test cache
.hypothesis/
**/.hypothesis/

# Playwright MCP artifacts
.playwright-mcp/

# Benchmarks
.benchmarks/
# Ephemeral benchmark output logs (re-generated on each run; source lives
# in benchmarks/*.py). Prevents re-committing after rm.
packages/*/benchmarks/*.log

# Mypy / Ruff caches
.mypy_cache/
.ruff_cache/

# Housekeeping
.temp_cleanup/

# Documentation builds
docs/_build/
docs/api/_build/
docs/*/_build/
_build/
site/
*.doctree

# Data
data/

# Generated outputs - all output directories
outputs/
output/
examples/outputs/
examples/output/

# Generated files in root and examples directories
/*.csv
/*.json
/examples/*.csv
/examples/*.json
/examples/customer_*.csv
/examples/processed_data.csv

# Task tracking storage (if they exist outside examples/data)
**/task_storage/
**/tasks/runs/
**/tasks/tasks/
**/tasks/metrics/
**/*_tracking/

# Jupyter Notebooks
.ipynb_checkpoints

# Local development
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.test
docs/build_output.txt
output.txt

# Build/release artifacts
test-release/
dist/

# Secrets baseline (local security scanning)
.secrets.baseline
